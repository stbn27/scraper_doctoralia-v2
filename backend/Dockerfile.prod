FROM python:3.12-slim-bookworm

WORKDIR /app

# Dependencias del sistema mínimas
RUN apt-get update && apt-get install -y \
    gcc \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Instalar dependencias Python (sin Playwright en prod)
COPY requirements.prod.txt .
RUN pip install --no-cache-dir -r requirements.prod.txt

# Copiar código fuente
COPY . .

EXPOSE 8000

# Sin --reload en producción: menor consumo de CPU y RAM
# --timeout-keep-alive: más alto que el timeout de Ollama (600s) para análisis IA largos
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2", "--timeout-keep-alive", "660"]
